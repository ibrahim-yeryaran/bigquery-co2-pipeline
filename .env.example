# Kopyala:  cp .env.example .env  (sonra kendi değerlerinle doldur)
# .env gitignore'lu — gerçek değerlerin asla commit edilmez.

# GCP proje kimliğin (BigQuery sandbox'ı açtığın proje)
GCP_PROJECT_ID=your-gcp-project-id

# Oluşturulacak dataset adları
BQ_RAW_DATASET=co2_raw
BQ_ANALYTICS_DATASET=co2_analytics

# BigQuery konumu (sandbox için US ya da EU)
BQ_LOCATION=US

# Kimlik doğrulama — İKİ seçenekten biri:
#  A) Application Default Credentials (önerilen, anahtar dosyası yok):
#       gcloud auth application-default login
#     Bu durumda aşağıdaki satırı boş bırak.
#  B) Service account anahtar dosyası (JSON):
#       Yolu buraya yaz. Dosya gitignore'lu olmalı, ASLA commit etme.
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
