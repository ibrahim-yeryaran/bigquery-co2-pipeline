# Copy:  cp .env.example .env  (then fill in your own values)
# .env is gitignored — your real values are never committed.

# Your GCP project id (the project where you enabled the BigQuery sandbox)
GCP_PROJECT_ID=your-gcp-project-id

# Dataset names to be created
BQ_RAW_DATASET=co2_raw
BQ_ANALYTICS_DATASET=co2_analytics

# BigQuery location (US or EU for the sandbox)
BQ_LOCATION=US

# Authentication — choose ONE of two options:
#  A) Application Default Credentials (recommended, no key file):
#       gcloud auth application-default login
#     In this case leave the line below empty.
#  B) Service account key file (JSON):
#       Put its path here. The file must be gitignored — NEVER commit it.
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
